# Large runtime assets — provided as volumes at runtime
checkpoints/
videos/
outputs/

# TRT engines are GPU-architecture-specific; user builds them inside container
*.engine

# Model weights and large binaries
*.pth
*.pt
*.onnx
*.safetensors

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
.eggs/
dist/
build/

# Git history (not needed in image)
.git/
.gitignore

# Output directories from local runs
output_*/

# Editor / OS cruft
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Jupyter notebook files (but keep notebook/ package — it's imported by the pipeline)
*.ipynb

# Docker meta-files (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
