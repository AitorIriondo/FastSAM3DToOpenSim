# TRT + service mode — use after building .engine files inside the container.
#
# Service (HTTP API):
#   docker compose up -d   (uses this file if set as env_file in compose)
#
# CLI batch run:
#   docker compose run --rm --env-file docker/trt.env fastsam3d-cli \
#     python demo_video_opensim.py --input /app/videos/test.mp4
FASTSAM_MODE=service
FOV_TRT=1
USE_TRT_BACKBONE=1
USE_COMPILE=1
DECODER_COMPILE=1
COMPILE_MODE=reduce-overhead
COMPILE_WARMUP_BATCH_SIZES=1
